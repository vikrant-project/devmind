# ── Local LLM Backend ─────────────────────────────────────────────────────────
# Which local backend: ollama | llamacpp | vllm | openai_compat (blank = auto)
DEVMIND_LLM_BACKEND=

# Ollama
OLLAMA_HOST=http://localhost:11434

# llama.cpp server
LLAMACPP_HOST=http://localhost:8080

# vLLM
VLLM_HOST=http://localhost:8000

# Generic OpenAI-compatible local server (LM Studio, Jan, TabbyAPI, etc.)
DEVMIND_LLM_BASE_URL=http://localhost:1234
DEVMIND_LLM_API_KEY=local

# ── Local Models Directory ────────────────────────────────────────────────────
DEVMIND_MODELS_DIR=~/devmind/models

# ── Model Routing (blank = auto-select) ───────────────────────────────────────
DEVMIND_PLANNING_MODEL=
DEVMIND_CODING_MODEL=
DEVMIND_DEBUG_MODEL=
DEVMIND_FIX_MODEL=
DEVMIND_REVIEW_MODEL=
DEVMIND_DOC_MODEL=
DEVMIND_TEST_MODEL=
DEVMIND_EMBEDDING_MODEL=

# ── Hardware and Performance ──────────────────────────────────────────────────
DEVMIND_GPU_ENABLED=false
DEVMIND_CONTEXT_SIZE=4096
DEVMIND_NUM_THREADS=
DEVMIND_GPU_LAYERS=

# ── Agent Behavior ────────────────────────────────────────────────────────────
DEVMIND_MODE=autonomous
DEVMIND_MAX_ITERATIONS=5
DEVMIND_WORKSPACE_ROOT=~/devmind/workspaces
DEVMIND_MEMORY_DB=~/.devmind/memory.db

# ── Sandbox ───────────────────────────────────────────────────────────────────
DEVMIND_SANDBOX=docker
DEVMIND_SANDBOX_CPU=2
DEVMIND_SANDBOX_MEMORY=1g
DEVMIND_SANDBOX_TIMEOUT=120

# ── VPS ───────────────────────────────────────────────────────────────────────
DEVMIND_VPS_HOST=
DEVMIND_VPS_USER=
