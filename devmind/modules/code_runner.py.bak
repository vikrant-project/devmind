"""Install deps + run project in sandbox.

Patched for production reliability:
- Python projects get an isolated `.venv` inside the workspace, so deps don't
  leak to the host and tests can find them.
- Long-running web servers (uvicorn / gunicorn / flask run / http.server / node
  server.js) are not actually executed in RUN — we only verify they import.
  Their behaviour is validated by the project's own test suite in the TEST phase.
- Static sites: validate HTML, never exec a browser-open command.
"""
from __future__ import annotations
import os
import re
import shlex
import sys
from html.parser import HTMLParser
from pathlib import Path

from ..tools.shell_tool import ShellResult
from ..workspace.sandbox import Sandbox
from ..utils.logger import log


_BROWSER_PHRASES = re.compile(
    r"\b(open\s+.+\s+in\s+.*browser|open\s+in\s+browser|visit\s+http|"
    r"navigate\s+to|double[- ]click|launch\s+browser|view\s+in\s+browser)\b",
    re.IGNORECASE,
)
_STATIC_TYPES = {"web_frontend", "static_site", "html", "frontend"}
_PYTHON_TYPES = {"python", "python_api", "python_cli", "python_script", "fastapi", "flask", "django"}
_PIP_INSTALL_RE = re.compile(r"\bpip3?\s+install\b", re.IGNORECASE)
_LONG_SERVERS = re.compile(
    r"\b(uvicorn|gunicorn|hypercorn|daphne|fastapi\s+run|flask\s+run|"
    r"manage\.py\s+runserver|python\s+-m\s+http\.server|http\.server|"
    r"node\s+\S*server|next\s+(dev|start)|npm\s+(start|run\s+dev)|"
    r"yarn\s+(start|dev)|pnpm\s+(start|dev))\b",
    re.IGNORECASE,
)


class _HTMLChecker(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self.errors: list[str] = []
        self.saw_html = False

    def handle_starttag(self, tag: str, attrs) -> None:  # type: ignore[override]
        if tag == "html":
            self.saw_html = True

    def error(self, message: str) -> None:  # type: ignore[override]
        self.errors.append(message)


def _validate_static_site(workspace: Path, plan: dict) -> ShellResult:
    missing: list[str] = []
    for entry in plan.get("files", []) or []:
        rel = entry.get("path", "")
        if rel and not (workspace / rel).exists():
            missing.append(rel)
    index = workspace / "index.html"
    if not index.exists():
        htmls = list(workspace.glob("**/*.html"))
        if not htmls:
            return ShellResult(cmd="<static-validate>", returncode=1, stdout="",
                               stderr="No HTML file found in workspace")
        index = htmls[0]
    try:
        html_text = index.read_text(encoding="utf-8", errors="replace")
    except Exception as e:
        return ShellResult(cmd="<static-validate>", returncode=1, stdout="",
                           stderr=f"cannot read {index}: {e}")
    checker = _HTMLChecker()
    try:
        checker.feed(html_text)
        checker.close()
    except Exception as e:
        return ShellResult(cmd="<static-validate>", returncode=1, stdout="",
                           stderr=f"HTML parse error: {e}")
    if missing:
        return ShellResult(cmd="<static-validate>", returncode=1, stdout="",
                           stderr=f"missing planned files: {', '.join(missing)}")
    stdout = f"static site OK: {index.name} ({len(html_text)} bytes)"
    if checker.errors:
        stdout += f"; html warnings: {len(checker.errors)}"
    return ShellResult(cmd="<static-validate>", returncode=0, stdout=stdout, stderr="")


def _is_browser_open(cmd: str) -> bool:
    if not cmd:
        return False
    if _BROWSER_PHRASES.search(cmd):
        return True
    stripped = cmd.strip()
    if stripped and stripped[0].isupper() and " " in stripped:
        shellish = re.search(
            r"[|&;<>$`]|--|\.\/|\b(python|node|npm|yarn|pnpm|go|cargo|java|bash|sh|make|docker|uvicorn|flask|gunicorn)\b",
            stripped,
        )
        if not shellish:
            return True
    return False


def _is_python_project(plan: dict, workspace: Path) -> bool:
    ptype = (plan.get("project_type") or "").lower()
    if ptype in _PYTHON_TYPES or "python" in ptype:
        return True
    install = (plan.get("install_command") or "").lower()
    if _PIP_INSTALL_RE.search(install) or "requirements.txt" in install:
        return True
    for entry in plan.get("files", []) or []:
        if (entry.get("path") or "").endswith(".py"):
            return True
    return False


def _ensure_venv(workspace: Path, sandbox: Sandbox) -> ShellResult:
    """Create workspace/.venv with a python interpreter present in the sandbox."""
    venv = workspace / ".venv"
    pip_path = venv / "bin" / "pip"
    if pip_path.exists():
        return ShellResult(cmd="<venv-exists>", returncode=0, stdout="venv already present", stderr="")
    # Use whatever `python3` is available in the execution environment. In the
    # subprocess sandbox this resolves to the host python; in the Docker
    # sandbox it resolves to the python in the container image. Don't pass the
    # host's `sys.executable` directly because that path won't exist inside a
    # container.
    candidates = ["python3", "python3.11", "python3.12", "python"]
    res: ShellResult | None = None
    for cand in candidates:
        log(f"[RUN] create venv: {cand} -m venv .venv")
        res = sandbox.exec(f"{cand} -m venv .venv 2>&1", timeout=180)
        if res.ok and pip_path.exists():
            break
        log(f"[RUN] venv via {cand} failed (rc={res.returncode}): {(res.stderr or res.stdout)[:300]}", level="WARN")
    if not res or not res.ok:
        return res or ShellResult(cmd="<venv>", returncode=1, stdout="", stderr="no python3 found")
    # Best-effort pip self-upgrade (non-fatal).
    up = sandbox.exec(".venv/bin/pip install --no-cache-dir --upgrade --quiet pip setuptools wheel 2>&1", timeout=180)
    if not up.ok:
        log(f"[RUN] pip self-upgrade skipped (non-fatal): {(up.stderr or up.stdout)[:200]}", level="WARN")
    return res


def _rewrite_for_venv(cmd: str) -> str:
    """Rewrite a command to use the workspace .venv binaries when available."""
    if not cmd:
        return cmd
    repl = [
        (r"\bpip3?\s+install\b", ".venv/bin/pip install"),
        (r"(?<![\w./])pip3?\b(?!\s*install)", ".venv/bin/pip"),
        (r"(?<![\w./])pytest\b", ".venv/bin/pytest"),
        (r"(?<![\w./])uvicorn\b", ".venv/bin/uvicorn"),
        (r"(?<![\w./])gunicorn\b", ".venv/bin/gunicorn"),
        (r"(?<![\w./])flask\b", ".venv/bin/flask"),
        (r"(?<![\w./])python3?\b", ".venv/bin/python"),
    ]
    out = cmd
    for pat, sub in repl:
        out = re.sub(pat, sub, out)
    return out


def _is_long_server(cmd: str) -> bool:
    return bool(cmd) and bool(_LONG_SERVERS.search(cmd))


# Map of import name -> pip package name for common deps. When an
# install_command isn't provided, infer one by scanning generated source files.
_IMPORT_TO_PKG = {
    "fastapi": "fastapi",
    "uvicorn": "uvicorn",
    "sqlalchemy": "sqlalchemy",
    "pydantic": "pydantic",
    "pytest": "pytest",
    "httpx": "httpx",
    "requests": "requests",
    "bs4": "beautifulsoup4",
    "beautifulsoup4": "beautifulsoup4",
    "flask": "flask",
    "django": "django",
    "jwt": "pyjwt",
    "jose": "python-jose",
    "passlib": "passlib[bcrypt]",
    "bcrypt": "bcrypt",
    "dotenv": "python-dotenv",
    "yaml": "pyyaml",
    "discord": "discord.py",
    "rich": "rich",
    "typer": "typer",
    "click": "click",
    "starlette": "starlette",
    "aiohttp": "aiohttp",
    "redis": "redis",
    "pymongo": "pymongo",
    "psycopg2": "psycopg2-binary",
    "matplotlib": "matplotlib",
    "numpy": "numpy",
    "pandas": "pandas",
    "tqdm": "tqdm",
    "tomli": "tomli",
    "alembic": "alembic",
    "httptools": "httptools",
    "websockets": "websockets",
    "pytest_asyncio": "pytest-asyncio",
    "asgi_lifespan": "asgi-lifespan",
}


_IMPORT_RE = re.compile(r"^\s*(?:from|import)\s+([A-Za-z_][A-Za-z0-9_]*)", re.MULTILINE)


def _infer_install_command(workspace: Path, plan: dict) -> str:
    """Scan generated .py files for top-level imports and produce a pip install command."""
    pkgs: set[str] = set()
    for entry in plan.get("files", []) or []:
        rel = entry.get("path", "")
        if not rel.endswith(".py"):
            continue
        path = workspace / rel
        if not path.exists():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            continue
        for m in _IMPORT_RE.finditer(text):
            mod = m.group(1)
            if mod in _IMPORT_TO_PKG:
                pkgs.add(_IMPORT_TO_PKG[mod])
    test_cmd = (plan.get("test_command") or "").lower()
    if "pytest" in test_cmd:
        pkgs.add("pytest")
    if not pkgs:
        return ""
    return "pip install " + " ".join(sorted(pkgs))


def install_and_run(
    workspace: Path, plan: dict, sandbox: Sandbox
) -> tuple[ShellResult, ShellResult | None]:
    install_cmd = (plan.get("install_command") or "").strip()
    run_cmd = (plan.get("run_command") or "").strip()
    project_type = (plan.get("project_type") or "").lower()

    is_static = project_type in _STATIC_TYPES or _is_browser_open(run_cmd)
    if is_static:
        log(f"[RUN] static-site validation (project_type={project_type or 'inferred'})")
        validation = _validate_static_site(workspace, plan)
        return validation, validation

    is_python = _is_python_project(plan, workspace)

    if is_python:
        venv_res = _ensure_venv(workspace, sandbox)
        if not venv_res.ok:
            return venv_res, None
        # Auto-infer install_command if the plan didn't include one.
        if not install_cmd:
            inferred = _infer_install_command(workspace, plan)
            if inferred:
                log(f"[RUN] inferred install_command from imports: {inferred}")
                install_cmd = inferred
        install_cmd = _rewrite_for_venv(install_cmd)
        run_cmd_effective = _rewrite_for_venv(run_cmd)
    else:
        run_cmd_effective = run_cmd

    install_result: ShellResult | None = None
    if install_cmd:
        # pip should not use a cache that may not be writable in the sandbox
        if is_python and ".venv/bin/pip" in install_cmd and "--no-cache-dir" not in install_cmd:
            install_cmd = install_cmd.replace(".venv/bin/pip install", ".venv/bin/pip install --no-cache-dir")
        log(f"[RUN] install: {install_cmd}")
        install_result = sandbox.exec(install_cmd, timeout=600)
        if not install_result.ok:
            return install_result, None

    if not run_cmd_effective:
        return install_result or ShellResult(cmd="", returncode=0, stdout="install ok", stderr=""), None

    # Long-running web server commands are validated by the test phase, not by
    # actually launching the server (which would hang).
    if _is_long_server(run_cmd_effective):
        log(f"[RUN] skipping long-server run_command (validated via tests): {run_cmd_effective}")
        smoke = install_result or ShellResult(cmd="<install-only>", returncode=0,
                                              stdout="install ok; server run skipped", stderr="")
        # If it's a Python server, do a quick import smoke test on main module.
        if is_python:
            main_mod = None
            m = re.search(r"\b([A-Za-z_][A-Za-z0-9_]*):[A-Za-z_]", run_cmd_effective)
            if m:
                main_mod = m.group(1)
            else:
                for entry in plan.get("files", []) or []:
                    p = entry.get("path", "")
                    if p.endswith("main.py") or p.endswith("app.py"):
                        main_mod = Path(p).stem
                        break
            if main_mod:
                import_check = (f".venv/bin/python -c \"import importlib, sys; "
                                f"sys.path.insert(0, '.'); importlib.import_module('{main_mod}'); "
                                f"print('import ok: {main_mod}')\"")
                log(f"[RUN] import smoke: {import_check}")
                smoke = sandbox.exec(import_check, timeout=60)
        return install_result or smoke, smoke

    log(f"[RUN] run: {run_cmd_effective}")
    run_result = sandbox.exec(run_cmd_effective, timeout=90)
    return install_result or ShellResult(cmd="", returncode=0, stdout="", stderr=""), run_result
